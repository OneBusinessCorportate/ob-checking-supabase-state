# Public — safe to expose, used in both API routes and (optionally) the browser
NEXT_PUBLIC_ARTYOM_SUPABASE_URL=https://rbtvbsbcycdlwmrzjwun.supabase.co
NEXT_PUBLIC_ARTYOM_SUPABASE_ANON_KEY=<anon key from Supabase dashboard>

# Secret — NEVER prefix with NEXT_PUBLIC_, only read in server-side API routes
ARTYOM_SUPABASE_SERVICE_ROLE_KEY=<service_role key from Supabase dashboard>

